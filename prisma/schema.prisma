// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model BankPeriod {
  id        String   @id @default(uuid())
  name      String
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  
  transactions BankTransaction[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("bank_periods")
}

model BankTransaction {
  id          String   @id @default(uuid())
  date        DateTime
  description String
  branch      String?
  documentId  String?  @map("document_id")
  amount      Decimal  @db.Decimal(15, 2)
  status      String   @default("PENDING") // PENDING, RECONCILED

  periodId    String   @map("period_id")
  period      BankPeriod @relation(fields: [periodId], references: [id])

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("bank_transactions")
}

model DianInvoice {
  id            String   @id // CUFE or CUDE (unique identifier from DIAN)
  documentType  String   @map("document_type")
  folio         String
  prefix        String
  issueDate     DateTime @map("issue_date")
  issuerNit     String   @map("issuer_nit")
  issuerName    String   @map("issuer_name")
  receiverNit   String   @map("receiver_nit")
  receiverName  String   @map("receiver_name")
  vat           Decimal  @db.Decimal(15, 2)
  inc           Decimal  @db.Decimal(15, 2)
  total         Decimal  @db.Decimal(15, 2)
  group         String

  // Optional fields from Excel
  currency          String?  @map("currency")
  paymentMethod     String?  @map("payment_method")
  paymentMedium     String?  @map("payment_medium")
  receptionDate     DateTime? @map("reception_date")
  ica               Decimal? @db.Decimal(15, 2)
  ic                Decimal? @db.Decimal(15, 2)
  stamp             Decimal? @db.Decimal(15, 2)
  incBags            Decimal? @map("inc_bags") @db.Decimal(15, 2)
  carbonTax         Decimal? @map("carbon_tax") @db.Decimal(15, 2)
  fuelTax           Decimal? @map("fuel_tax") @db.Decimal(15, 2)
  dataTax           Decimal? @map("data_tax") @db.Decimal(15, 2)
  icl               Decimal? @db.Decimal(15, 2)
  inpp              Decimal? @db.Decimal(15, 2)
  ibua              Decimal? @db.Decimal(15, 2)
  icui              Decimal? @db.Decimal(15, 2)
  withheldVat        Decimal? @map("withheld_vat") @db.Decimal(15, 2)
  withheldIncome     Decimal? @map("withheld_income") @db.Decimal(15, 2)
  withheldIca       Decimal? @map("withheld_ica") @db.Decimal(15, 2)
  status             String?

  // New fields for download and accounting tracking
  isAccounted        Boolean  @default(false) @map("is_accounted")
  isDownloaded       Boolean  @default(false) @map("is_downloaded")
  XMLURL             String?  @map("xml_url")
  PDFURL             String?  @map("pdf_url")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([id])
  @@map("dian_invoices")
}

model SiigoCredential {
  id        String   @id @default(uuid())
  username  String
  accessKey String   @map("access_key")
  partnerId String?  @map("partner_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("siigo_credentials")
}

model SiigoAccount {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  category    String?
  class       String?
  level       Int?
  active      Boolean  @default(true)
  
  expenseConcepts BankExpenseConcept[]
  providerExpenseConfigs ProviderAccountingConfig[] @relation("ProviderExpenseAccount")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("siigo_accounts")
}

model BankExpenseConcept {
  id          String   @id @default(uuid())
  alias       String
  pattern     String   // Keyword to match in transaction description
  
  accountCode String   @map("account_code")
  account     SiigoAccount @relation(fields: [accountCode], references: [code])

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("bank_expense_concepts")
}

model SiigoSetting {
  id                String   @id @default(uuid())
  bankAccountCode   String?  @map("bank_account_code") // Cuenta del banco (e.g. 111005)
  journalDocumentId String?  @map("journal_document_id") // Comprobante (e.g. CC-1)
  costCenterCode    String?  @map("cost_center_code")
  bankNit           String?  @map("bank_nit") // NIT del Banco para asignar gastos

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("siigo_settings")
}

model SiigoDocumentType {
  id          Int      @id // The Siigo ID (e.g. 2445)
  code        String   // The Code (e.g. "CC")
  name        String   // The Name (e.g. "Comprobante de Egreso")
  description String?
  active      Boolean  @default(true)
  type        String?  // 'Journal', 'Invoice', etc.

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("siigo_document_types")
}

model SiigoSupplier {
  id            String   @id @default(uuid())
  siigoId       String   @unique // ID de Siigo (puede ser UUID o número como string)
  identification String   // NIT o identificación
  name          String
  email         String?
  phone         String?
  address       String?
  city          String?
  active        Boolean  @default(true)
  type          String?  // "Supplier", "Customer", etc.

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("siigo_suppliers")
}

model SiigoCostCenter {
  id          String   @id @default(uuid())
  siigoId     String   @unique // ID de Siigo (puede ser UUID o número como string)
  code        String
  name        String
  active      Boolean  @default(true)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("siigo_cost_centers")
}

model SiigoProduct {
  id          String   @id @default(uuid())
  siigoId     String   @unique // ID de Siigo (puede ser UUID o número como string)
  code        String
  name        String
  description String?
  active      Boolean  @default(true)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("siigo_products")
}

model SiigoTax {
  id          String   @id @default(uuid())
  siigoId     String   @unique // ID de Siigo (puede ser UUID o número como string)
  name        String
  type        String?  // Tipo de impuesto
  rate        Decimal? @db.Decimal(5, 2) // Porcentaje
  active      Boolean  @default(true)

  providerWithholdingConfigs ProviderAccountingConfig[] @relation("ProviderWithholdingTax")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("siigo_taxes")
}

model ProviderAccountingConfig {
  providerNit String @id @map("provider_nit")

  expenseAccountId String?     @map("expense_account_id")
  expenseAccount   SiigoAccount? @relation("ProviderExpenseAccount", fields: [expenseAccountId], references: [id])

  withholdingTaxId String?   @map("withholding_tax_id")
  withholdingTax   SiigoTax? @relation("ProviderWithholdingTax", fields: [withholdingTaxId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("provider_accounting_configs")
}

model SiigoPaymentType {
  id          String   @id @default(uuid())
  siigoId     String   @unique // ID de Siigo (puede ser UUID o número como string)
  name        String
  active      Boolean  @default(true)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("siigo_payment_types")
}

model SiigoCurrency {
  id          String   @id @default(uuid())
  code        String   @unique // Código de moneda (COP, USD, etc.)
  name        String
  symbol      String?
  active      Boolean  @default(true)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("siigo_currencies")
}
